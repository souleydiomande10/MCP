# ══════════════════════════════════════════════════════════
# MARKET CENTER PLACE — Variables d'environnement
# Copier ce fichier en .env et remplir toutes les valeurs
# Ne jamais mettre .env dans Git !
# ══════════════════════════════════════════════════════════

# ── ENVIRONNEMENT ──
NODE_ENV=production
PORT=5000

# ── BASE DE DONNÉES MySQL ──
DB_HOST=127.0.0.1
DB_USER=mcp_user
DB_PASSWORD=CHANGER_MOT_DE_PASSE_FORT
DB_NAME=mcp_db
DB_SSL=false

# ── JWT (générer avec : openssl rand -hex 32) ──
JWT_SECRET=CHANGER_CLE_JWT_32_CHARS_MINIMUM_OBLIGATOIRE
JWT_REFRESH=CHANGER_CLE_REFRESH_32_CHARS_MINIMUM_OBLIGATOIRE

# ── CINETPAY (cinetpay.com) ──
CINETPAY_API_KEY=VOTRE_API_KEY_CINETPAY
CINETPAY_SITE_ID=VOTRE_SITE_ID_CINETPAY
CINETPAY_SECRET=VOTRE_SECRET_CINETPAY
CINETPAY_NOTIFY_URL=https://marketcenterplace.ci/api/webhooks/cinetpay

# ── WAVE CI (business@wave.com) ──
WAVE_API_KEY=VOTRE_API_KEY_WAVE
WAVE_SECRET=VOTRE_SECRET_WAVE

# ── SMS — TWILIO (twilio.com) ──
TWILIO_SID=VOTRE_ACCOUNT_SID_TWILIO
TWILIO_TOKEN=VOTRE_AUTH_TOKEN_TWILIO
TWILIO_PHONE=+1XXXXXXXXXX

# ── SMS — ORANGE CI (optionnel) ──
ORANGE_SMS_TOKEN=VOTRE_TOKEN_ORANGE_SMS

# ── CLOUDINARY (images produits) ──
CLOUDINARY_CLOUD_NAME=VOTRE_CLOUD_NAME
CLOUDINARY_API_KEY=VOTRE_API_KEY_CLOUDINARY
CLOUDINARY_API_SECRET=VOTRE_SECRET_CLOUDINARY

# ── EMAIL (notifications) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=contact@marketcenterplace.ci
SMTP_PASS=VOTRE_MOT_DE_PASSE_EMAIL

# ── DOMAINE ──
SITE_URL=https://marketcenterplace.ci
ADMIN_EMAIL=admin@marketcenterplace.ci
